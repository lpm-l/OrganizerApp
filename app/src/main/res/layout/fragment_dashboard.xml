<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".DashboardFragment"
    android:background="#f5f5f5">

    <TextView
        android:id="@+id/tvDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resumen de Tareas"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/chartContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:background="@android:color/white"
        android:padding="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDashboardTitle"
        app:layout_constraintBottom_toTopOf="@id/legendContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Completed Bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="bottom|center_horizontal">

            <TextView
                android:id="@+id/tvCompletedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/barCompleted"
                android:layout_width="50dp"
                android:layout_height="0dp"
                android:background="#4CAF50" />
        </LinearLayout>

        <!-- Pending Bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="bottom|center_horizontal">

            <TextView
                android:id="@+id/tvPendingValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/barPending"
                android:layout_width="50dp"
                android:layout_height="0dp"
                android:background="#FFC107" />
        </LinearLayout>

        <!-- Overdue Bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="bottom|center_horizontal">

            <TextView
                android:id="@+id/tvOverdueValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/barOverdue"
                android:layout_width="50dp"
                android:layout_height="0dp"
                android:background="#F44336" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/legendContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/DashboardMessage"
        app:layout_constraintTop_toBottomOf="@id/chartContainer"
        android:layout_marginBottom="20dp"
        >

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Completadas"
            android:textAlignment="center"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pendientes"
            android:textAlignment="center"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Atrasadas"
            android:textAlignment="center"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/DashboardMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bottom text"
        android:textSize="18sp"
        android:textStyle="normal"
        android:textColor="#333"
        app:layout_constraintTop_toBottomOf="@+id/legendContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />





</androidx.constraintlayout.widget.ConstraintLayout>
